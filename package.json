{
  "name": "@mukundakatta/agentmemory",
  "version": "0.2.0",
  "description": "Honest pull-model alternative to Anthropic Dreaming. Time-bucketed episodic store + on-demand summarizer for LLM agents. Reversible deletes, no silent context injection, no background consolidation. Includes Postgres adapter and Claude demo.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./store": "./src/store.js",
    "./summarizer": "./src/summarizer.js",
    "./drift": "./src/drift.js",
    "./postgres": "./src/adapters/postgres.js"
  },
  "files": [
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test tests/test.js",
    "test:postgres": "node --test tests/postgres.test.js",
    "test:all": "node --test tests/"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30",
    "pg": ">=8"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": { "optional": true },
    "pg": { "optional": true }
  },
  "keywords": [
    "ai",
    "agents",
    "llm",
    "memory",
    "claude",
    "anthropic",
    "rag",
    "episodic",
    "summarization",
    "dreaming-alternative"
  ],
  "author": "MukundaKatta",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MukundaKatta/agentmemory.git"
  },
  "homepage": "https://github.com/MukundaKatta/agentmemory#readme",
  "bugs": {
    "url": "https://github.com/MukundaKatta/agentmemory/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {}
}
